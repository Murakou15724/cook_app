<!DOCTYPE html>
<html>
  <head>
    <title>料理アプリ</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-shell">
      <header class="header">
        <div>
          <p class="eyebrow">Cook Plan</p>
          <%= link_to "料理アプリ", logged_in? ? root_path : login_path, class: "brand" %>
        </div>

        <% if logged_in? %>
          <div class="header-actions">
            <% if current_user.admin? %>
              <%= link_to "管理者ホーム", admin_root_path, class: "admin-chip" %>
            <% end %>
            <%= link_to "全ページ", dev_pages_path, class: "ghost-button" %>
            <%= button_to "ログアウト", logout_path, method: :delete, class: "link-button" %>
          </div>
        <% end %>
      </header>

      <div id="flash-messages" class="flash-stack" aria-live="polite">
        <%= render "shared/flash_messages" %>
      </div>

      <main class="app-main">
        <%= yield %>
      </main>

      <% if logged_in? %>
        <nav class="bottom-nav" aria-label="主要ナビゲーション">
          <%= bottom_nav_link("ホーム", root_path, :home, active: current_page?(root_path)) %>
          <%= bottom_nav_link("献立", meal_plans_path, :calendar, active: controller_name == "meal_plans" && action_name != "new" && action_name != "create") %>
          <%= bottom_nav_link("作成", new_meal_plan_path, :plus, active: controller_name == "meal_plans" && (action_name == "new" || action_name == "create")) %>
          <%= bottom_nav_link("買い物", shopping_items_path, :basket, active: controller_name == "shopping_items") %>
          <%= bottom_nav_link("履歴", cooking_records_path, :diary, active: controller_name == "cooking_records") %>
          <%= bottom_nav_link("設定", settings_path, :settings, active: controller_name == "settings") %>
        </nav>
      <% end %>
    </div>
  </body>
</html>
