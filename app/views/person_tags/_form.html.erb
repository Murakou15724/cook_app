<%= form_with url: person_tag.persisted? ? person_tag_path(person_tag) : person_tags_path,
              method: person_tag.persisted? ? :patch : :post,
              class: "form-card" do |form| %>
  <div class="form-group"><%= form.label :name, "人物名" %><%= form.text_field :name, value: person_tag.name %></div>
  <label class="check-row"><%= check_box_tag :default_selected, "1", person_tag.default_selected? %> 新規献立で初期選択</label>
  <%= form.submit person_tag.persisted? ? "更新する" : "作成する", class: "primary-button" %>
<% end %>
