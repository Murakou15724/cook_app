<section class="page-title">
  <p class="eyebrow">People</p>
  <h1>人物タグ管理</h1>
  <p>献立全体と過去料理に付与する人物タグを管理します。</p>
</section>

<section class="card">
  <div class="section-title"><h2>新規作成</h2></div>
  <%= form_with url: person_tags_path, class: "form-card" do |form| %>
    <div class="form-group"><%= form.label :name, "人物名" %><%= form.text_field :name, placeholder: "例: 家族" %></div>
    <label class="check-row"><%= check_box_tag :default_selected %> 新規献立で初期選択</label>
    <%= form.submit "作成する", class: "primary-button" %>
  <% end %>
</section>

<section class="card">
  <div class="section-title"><h2>登録済み</h2><span class="count-badge"><%= @person_tags.size %>件</span></div>
  <% if @person_tags.any? %>
    <% @person_tags.each do |tag| %>
      <div class="dev-link-row">
        <span><%= tag.name %><%= " / 初期選択" if tag.default_selected? %></span>
        <%= link_to "編集", edit_person_tag_path(tag) %>
      </div>
    <% end %>
  <% else %>
    <p class="empty-state">人物タグはまだありません。</p>
  <% end %>
</section>
