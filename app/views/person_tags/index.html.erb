<section class="page-title">
  <p class="eyebrow">People</p>
  <h1>人物タグ管理</h1>
  <p>献立全体と過去料理に付与する人物タグを管理します。</p>
</section>

<section class="card">
  <div class="section-title"><h2>新規作成</h2></div>
  <%= render "shared/error_messages", object: @person_tag %>
  <%= render "person_tags/form", person_tag: @person_tag %>
</section>

<section class="card">
  <div class="section-title"><h2>登録済み</h2><span class="count-badge"><%= @person_tags.size %>件</span></div>
  <% if @person_tags.any? %>
    <% @person_tags.each do |tag| %>
      <div class="dev-link-row">
        <span><%= tag.name %><%= " / 初期選択" if tag.default_selected? %></span>
        <span>
          <%= link_to "編集", edit_person_tag_path(tag) %>
          <%= button_to "削除", person_tag_path(tag), method: :delete, class: "link-button" %>
        </span>
      </div>
    <% end %>
  <% else %>
    <p class="empty-state">人物タグはまだありません。</p>
  <% end %>
</section>
