<section class="page-title with-action">
  <div>
    <p class="eyebrow">今日の予定</p>
    <h1>今日の献立</h1>
  </div>
  <%= link_to "献立を作成", new_meal_plan_path, class: "primary-button title-action" %>
  <p><%= app_date(@today) %></p>
</section>

<section class="card">
  <div class="section-title">
    <h2><%= app_date(@today) %></h2>
  </div>

  <% ["lunch", "dinner"].each do |meal_type| %>
    <% meal_plan = @meal_plans[meal_type] %>
    <div class="meal-block">
      <div class="meal-head">
        <div class="meal-head-main">
          <span class="meal-label"><%= meal_type_label(meal_type) %></span>
          <% if meal_plan&.person_tags&.any? %>
            <span class="meal-tag-line"><%= meal_plan.person_tags.map(&:name).join("、") %></span>
          <% end %>
        </div>
      </div>

      <% if meal_plan.present? %>
        <% meal_plan.plan_dishes.ordered.each do |dish| %>
          <article class="dish">
            <div class="dish-icon"><%= dish_icon(dish.name) %></div>
            <div>
              <h3><%= dish.name %><%= "（外食）" if dish.eating_out? %></h3>
              <% ingredients = dish.dish_ingredients.sort_by(&:id).map(&:name).reject(&:blank?) %>
              <% if ingredients.any? %>
                <p class="meal-dish-detail">
                  <span>食材</span>
                  <%= ingredients.join(", ") %>
                </p>
              <% end %>
              <% if dish.memo.present? %>
                <p class="meal-dish-detail">
                  <span>メモ</span>
                  <%= dish.memo %>
                </p>
              <% end %>
            </div>
          </article>
        <% end %>
      <% else %>
        <p class="empty-state">未登録</p>
      <% end %>
    </div>
  <% end %>
</section>
