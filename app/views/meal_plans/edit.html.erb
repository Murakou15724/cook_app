<section class="page-title">
  <p class="eyebrow">Edit</p>
  <h1>献立編集</h1>
  <p><%= l(@meal_plan.meal_date, format: :long) %> / <%= meal_type_label(@meal_plan.meal_type) %></p>
</section>

<%= form_with url: meal_plan_path(@meal_plan), method: :patch, class: "form-card" do |form| %>
  <% @meal_plan.plan_dishes.ordered.each_with_index do |dish, index| %>
    <section class="dish-card">
      <div class="section-title"><h2>料理 <%= index + 1 %></h2><span class="status-badge"><%= dish.eating_out? ? "外食" : "通常" %></span></div>
      <div class="form-group"><%= label_tag "dish_#{dish.id}", "料理名" %><%= text_field_tag "dish_#{dish.id}", dish.name %></div>
      <div class="form-group"><%= label_tag "memo_#{dish.id}", "メモ" %><%= text_area_tag "memo_#{dish.id}", dish.memo %></div>
    </section>
  <% end %>
  <%= form.submit "更新する", class: "primary-button" %>
<% end %>

<div class="card">
  <div class="section-title"><h2>削除</h2></div>
  <%= button_to "献立を削除", meal_plan_path(@meal_plan), method: :delete, class: "danger-button" %>
</div>
