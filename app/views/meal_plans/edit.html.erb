<section class="page-title">
  <p class="eyebrow">Edit</p>
  <h1>献立編集</h1>
  <p><%= l(@meal_plan.meal_date, format: :long) %> / <%= meal_type_label(@meal_plan.meal_type) %></p>
</section>

<%= render "shared/error_messages", object: @meal_plan %>

<%= form_with url: meal_plan_path(@meal_plan), method: :patch, class: "form-card", html: { autocomplete: "off" }, data: { controller: "meal-plan-form" } do |form| %>
  <div class="meal-plan-basic-fields">
    <div class="form-group">
      <%= form.label :meal_date, "日付" %>
      <%= form.date_field :meal_date, value: @meal_plan.meal_date, autocomplete: "off" %>
    </div>

    <div class="form-group">
      <label>食事区分</label>
      <div class="segment vertical">
        <label><%= radio_button_tag :meal_type, "lunch", @meal_plan.lunch? %> 昼食</label>
        <label><%= radio_button_tag :meal_type, "dinner", @meal_plan.dinner? %> 夕食</label>
      </div>
    </div>
  </div>

  <div data-meal-plan-form-target="dishes">
    <% @dish_inputs.each_with_index do |dish, index| %>
      <section class="dish-card" data-meal-plan-form-target="dish" data-dish-index="<%= index %>">
        <div class="section-title">
          <h2>料理 <span data-meal-plan-form-target="dishNumber"><%= index + 1 %></span></h2>
          <button type="button" class="danger-icon-button" data-meal-plan-form-target="removeDishButton" data-action="meal-plan-form#removeDish" <%= "hidden" if index.zero? %>>削除</button>
        </div>
        <div class="form-group">
          <%= label_tag "dishes_#{index}_name", "料理名" %>
          <%= text_field_tag "dishes[#{index}][name]", dish["name"], id: "dishes_#{index}_name", autocomplete: "off" %>
        </div>
        <div class="form-group">
          <div class="section-title compact">
            <h2>必要食材</h2>
            <span class="ingredient-shopping-heading">買い物</span>
          </div>
          <div class="ingredient-fields" data-meal-plan-form-target="ingredients">
            <% dish.fetch("ingredients", []).each_with_index do |ingredient, ingredient_index| %>
              <div class="ingredient-field" data-meal-plan-form-target="ingredient">
                <button type="button" class="danger-icon-button" aria-label="食材を削除" data-action="meal-plan-form#removeIngredient">-</button>
                <%= text_field_tag "dishes[#{index}][ingredients][#{ingredient_index}][name]", ingredient["name"], id: "dishes_#{index}_ingredients_#{ingredient_index}_name", autocomplete: "off", data: { action: "input->meal-plan-form#syncIngredientCheck" } %>
                <label class="inline-check">
                  <%= check_box_tag "dishes[#{index}][ingredients][#{ingredient_index}][add_to_shopping_list]", "1", ingredient["name"].present? ? ingredient["add_to_shopping_list"] != false && ingredient["add_to_shopping_list"] != "0" : false, aria: { label: "買い物リストに追加" }, data: { action: "change->meal-plan-form#preventEmptyIngredientCheck" } %>
                </label>
              </div>
            <% end %>
          </div>
          <button type="button" class="link-button ingredient-add-button" data-action="meal-plan-form#addIngredient">食材を追加</button>
        </div>
        <div class="form-group">
          <%= label_tag "dishes_#{index}_memo", "メモ" %>
          <%= text_area_tag "dishes[#{index}][memo]", dish["memo"], id: "dishes_#{index}_memo", autocomplete: "off" %>
        </div>
      </section>
    <% end %>
  </div>

  <button type="button" class="secondary-button full-width" data-action="meal-plan-form#addDish">料理を追加</button>

  <template data-meal-plan-form-target="dishTemplate">
    <section class="dish-card" data-meal-plan-form-target="dish" data-dish-index="__DISH_INDEX__">
      <div class="section-title">
        <h2>料理 <span data-meal-plan-form-target="dishNumber">__DISH_NUMBER__</span></h2>
        <button type="button" class="danger-icon-button" data-meal-plan-form-target="removeDishButton" data-action="meal-plan-form#removeDish">削除</button>
      </div>
      <div class="form-group">
        <label for="dishes___DISH_INDEX___name">料理名</label>
        <input type="text" name="dishes[__DISH_INDEX__][name]" id="dishes___DISH_INDEX___name" autocomplete="off">
      </div>
      <div class="form-group">
        <div class="section-title compact">
          <h2>必要食材</h2>
          <span class="ingredient-shopping-heading">買い物</span>
        </div>
        <div class="ingredient-fields" data-meal-plan-form-target="ingredients">
          <% 3.times do |ingredient_index| %>
            <div class="ingredient-field" data-meal-plan-form-target="ingredient">
              <button type="button" class="danger-icon-button" aria-label="食材を削除" data-action="meal-plan-form#removeIngredient">-</button>
              <input type="text" name="dishes[__DISH_INDEX__][ingredients][<%= ingredient_index %>][name]" id="dishes___DISH_INDEX___ingredients_<%= ingredient_index %>_name" autocomplete="off" data-action="input->meal-plan-form#syncIngredientCheck">
              <label class="inline-check">
                <input type="checkbox" name="dishes[__DISH_INDEX__][ingredients][<%= ingredient_index %>][add_to_shopping_list]" value="1" aria-label="買い物リストに追加" data-action="change->meal-plan-form#preventEmptyIngredientCheck">
              </label>
            </div>
          <% end %>
        </div>
        <button type="button" class="link-button ingredient-add-button" data-action="meal-plan-form#addIngredient">食材を追加</button>
      </div>
      <div class="form-group">
        <label for="dishes___DISH_INDEX___memo">メモ</label>
        <textarea name="dishes[__DISH_INDEX__][memo]" id="dishes___DISH_INDEX___memo" autocomplete="off"></textarea>
      </div>
    </section>
  </template>

  <template data-meal-plan-form-target="ingredientTemplate">
    <div class="ingredient-field" data-meal-plan-form-target="ingredient">
      <button type="button" class="danger-icon-button" aria-label="食材を削除" data-action="meal-plan-form#removeIngredient">-</button>
      <input type="text" name="dishes[__DISH_INDEX__][ingredients][__INGREDIENT_INDEX__][name]" id="dishes___DISH_INDEX___ingredients___INGREDIENT_INDEX___name" autocomplete="off" data-action="input->meal-plan-form#syncIngredientCheck">
      <label class="inline-check">
        <input type="checkbox" name="dishes[__DISH_INDEX__][ingredients][__INGREDIENT_INDEX__][add_to_shopping_list]" value="1" aria-label="買い物リストに追加" data-action="change->meal-plan-form#preventEmptyIngredientCheck">
      </label>
    </div>
  </template>

  <section class="card">
    <div class="section-title">
      <h2>人物タグ</h2>
      <span class="count-badge"><%= @person_tags.size %>件</span>
    </div>
    <% if @person_tags.any? %>
      <div class="chip-list">
        <% @person_tags.each do |tag| %>
          <label class="check-row">
            <%= check_box_tag "person_tag_ids[]", tag.id, @selected_person_tag_ids.include?(tag.id) %>
            <%= tag.name %>
          </label>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">人物タグはまだありません。</p>
    <% end %>
  </section>

  <%= form.submit "更新する", class: "primary-button" %>
<% end %>

<section class="card">
  <div class="section-title"><h2>完全削除</h2></div>
  <p class="small-note">この献立と料理、必要食材、関連する買い物リスト項目を削除します。</p>
  <%= button_to "献立を削除", meal_plan_path(@meal_plan), method: :delete, class: "danger-button full-width", data: { turbo_confirm: "本当に削除しますか？" } %>
</section>
