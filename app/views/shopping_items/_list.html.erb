<%= turbo_frame_tag "shopping_items", data: { controller: "shopping-edit" } do %>
  <section class="page-title">
    <p class="eyebrow">Shopping</p>
    <h1>買い物リスト</h1>
    <p>必要な食材を確認し、購入済みにします。</p>
  </section>

  <%= render "shared/error_messages", object: @shopping_item %>

  <section class="card manual-add-card">
    <div class="section-title compact"><h2>手動追加</h2></div>
    <%= form_with model: @shopping_item, url: shopping_items_path, class: "compact-add-form", html: { autocomplete: "off" } do |form| %>
      <div class="form-group">
        <%= form.label :name, "食材名" %>
        <%= form.text_field :name, autocomplete: "off" %>
      </div>
      <%= form.submit "追加", class: "primary-button" %>
    <% end %>
  </section>

  <%= render "shopping_items/unpurchased_group" %>
  <%= render "shopping_items/purchased_group" %>

  <div class="drawer-backdrop" hidden data-shopping-edit-target="backdrop" data-action="click->shopping-edit#close"></div>
  <section class="edit-drawer" hidden data-shopping-edit-target="drawer" aria-modal="true" role="dialog" aria-labelledby="shopping-edit-title">
    <div class="drawer-handle"></div>
    <div class="drawer-head">
      <h2 id="shopping-edit-title">食材を編集</h2>
      <button type="button" class="close-btn" aria-label="閉じる" data-action="shopping-edit#close">×</button>
    </div>

    <label for="shopping-edit-name">食材名</label>
    <input id="shopping-edit-name" type="text" data-shopping-edit-target="nameInput" autocomplete="off">
    <p class="drawer-note" data-shopping-edit-target="context"></p>
    <p class="drawer-note">保存・削除は非同期で反映されます。</p>

    <div class="drawer-actions">
      <button type="button" class="save-btn" data-action="shopping-edit#save">保存する</button>
      <button type="button" class="delete-btn" data-action="shopping-edit#destroy">削除する</button>
    </div>
  </section>
<% end %>
