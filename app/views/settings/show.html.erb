<section class="page-title">
  <h1>設定ページ</h1>
  <p>プロフィールと人物タグの管理をまとめています。</p>
</section>

<section class="card">
  <div class="section-title">
    <h2>アカウント</h2>
  </div>

  <div class="dev-link-row">
    <span>プロフィール編集</span>
    <span><%= link_to "開く", edit_profile_path %></span>
  </div>
</section>

<section class="card"
         data-controller="passkey"
         data-passkey-registration-options-url-value="<%= passkey_registration_options_path %>"
         data-passkey-registration-url-value="<%= passkeys_path %>">
  <div class="section-title">
    <h2>パスキー</h2>
  </div>

  <p class="small-note">端末の生体認証やPINを使ってログインできます。顔写真や指紋データは保存しません。</p>
  <button type="button"
          class="secondary-button full-width"
          data-action="passkey#register">パスキーを登録</button>
  <p class="small-note passkey-status" data-passkey-target="status" aria-live="polite"></p>

  <% if @passkeys.any? %>
    <div class="dev-link-row">
      <span>登録済み</span>
      <span><%= @passkeys.count %>件</span>
    </div>
  <% end %>
</section>

<section class="card">
  <div class="section-title">
    <h2>タグ設定</h2>
  </div>

  <div class="dev-link-row">
    <span>人物タグ設定</span>
    <span><%= link_to "開く", person_tags_path %></span>
  </div>
</section>
