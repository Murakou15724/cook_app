<section class="page-title">
  <p class="eyebrow">Records</p>
  <h1>過去料理一覧</h1>
  <p>料理名・メモ・人物タグで振り返ります。</p>
</section>

<section class="card">
  <div class="section-title"><h2>検索</h2><span class="count-badge"><%= @cooking_records.size %>件</span></div>
  <div class="form-group"><input type="search" placeholder="料理名・メモで検索"></div>
  <p class="small-note">検索処理は後続issueで実装します。人物タグ複数選択はAND検索です。</p>
</section>

<% if @cooking_records.any? %>
  <section class="card">
    <% @cooking_records.each do |record| %>
      <div class="record-row">
        <div class="dish-icon"><%= record.eating_out? ? "外" : "食" %></div>
        <div>
          <h3><%= link_to record.name, cooking_record_path(record) %></h3>
          <p><%= l(record.cooked_on, format: :long) %> / <%= meal_type_label(record.meal_type) %></p>
        </div>
      </div>
    <% end %>
  </section>
<% else %>
  <p class="empty-state">過去料理はまだありません。</p>
<% end %>
