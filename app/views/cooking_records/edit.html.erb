<section class="page-title">
  <p class="eyebrow">Record Edit</p>
  <h1>過去料理編集</h1>
  <p><%= @cooking_record.name %></p>
</section>

<%= form_with url: cooking_record_path(@cooking_record), method: :patch, class: "form-card", html: { autocomplete: "off" } do |form| %>
  <div class="form-group"><%= form.label :name, "料理名" %><%= form.text_field :name, value: @cooking_record.name, autocomplete: "off" %></div>
  <div class="form-group"><%= form.label :cooked_on, "食事日" %><%= form.date_field :cooked_on, value: @cooking_record.cooked_on, autocomplete: "off" %></div>
  <div class="form-group"><%= form.label :memo, "メモ" %><%= form.text_area :memo, value: @cooking_record.memo, autocomplete: "off" %></div>
  <%= form.submit "更新する", class: "primary-button" %>
<% end %>
