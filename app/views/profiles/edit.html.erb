<section class="page-title">
  <h1>プロフィール編集</h1>
  <p>メールアドレスとパスワードのみ変更できます。</p>
</section>

<%= render "shared/error_messages", object: @user %>

<%= form_with model: @user, url: profile_path, class: "form-card" do |form| %>
  <div class="field">
    <%= form.label :email, "メールアドレス" %>
    <%= form.email_field :email, autocomplete: "email", required: true %>
  </div>

  <div class="field">
    <%= form.label :password, "新しいパスワード" %>
    <%= form.password_field :password, autocomplete: "new-password", minlength: 6 %>
  </div>

  <div class="field">
    <%= form.label :password_confirmation, "新しいパスワード確認" %>
    <%= form.password_field :password_confirmation, autocomplete: "new-password", minlength: 6 %>
  </div>

  <%= form.submit "更新する", class: "primary-button" %>
<% end %>
