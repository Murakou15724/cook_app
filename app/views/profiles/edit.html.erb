<section class="page-title">
  <h1>プロフィール編集</h1>
  <p>ニックネーム、メールアドレス、パスワードを変更できます。</p>
</section>

<%= render "shared/error_messages", object: @user %>

<%= form_with model: @user, url: profile_path, class: "form-card", html: { autocomplete: "off" } do |form| %>
  <div class="field">
    <%= form.label :email, "メールアドレス" %>
    <%= form.email_field :email, autocomplete: "off", required: true %>
  </div>

  <div class="field">
    <%= form.label :nickname, "ニックネーム" %>
    <%= form.text_field :nickname, autocomplete: "off", maxlength: 20 %>
  </div>

  <div class="field">
    <%= form.label :password, "新しいパスワード" %>
    <%= form.password_field :password, autocomplete: "off", minlength: 6, maxlength: 20, pattern: "[A-Za-z0-9]*" %>
  </div>

  <div class="field">
    <%= form.label :password_confirmation, "新しいパスワード確認" %>
    <%= form.password_field :password_confirmation, autocomplete: "off", minlength: 6, maxlength: 20, pattern: "[A-Za-z0-9]*" %>
  </div>

  <%= form.submit "更新する", class: "primary-button" %>
<% end %>
