<section class="page-title">
  <p class="eyebrow">Admin</p>
  <h1>過去料理管理</h1>
</section>

<section class="card">
  <% if @cooking_records.any? %>
    <% @cooking_records.each do |record| %>
      <div class="dev-link-row"><span><%= record.user.email %> / <%= record.name %></span><%= link_to "詳細", admin_cooking_record_path(record) %></div>
    <% end %>
  <% else %>
    <p class="empty-state">過去料理はありません。</p>
  <% end %>
</section>
