<section class="page-title">
  <p class="eyebrow">Admin</p>
  <h1>過去料理編集</h1>
</section>

<%= form_with url: admin_cooking_record_path(@cooking_record), method: :patch, class: "form-card" do |form| %>
  <div class="form-group"><%= form.label :name, "料理名" %><%= form.text_field :name, value: @cooking_record.name %></div>
  <%= form.submit "更新する", class: "primary-button" %>
<% end %>
