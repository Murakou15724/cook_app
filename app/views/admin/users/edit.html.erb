<section class="page-title">
  <p class="eyebrow">Admin</p>
  <h1>ユーザー編集</h1>
  <p><%= @user.email %></p>
</section>

<%= form_with url: admin_user_path(@user), method: :patch, class: "form-card" do |form| %>
  <div class="form-group"><%= form.label :email, "メールアドレス" %><%= form.email_field :email, value: @user.email %></div>
  <div class="form-group"><%= form.label :role, "権限" %><%= form.select :role, User.roles.keys.map { |role| [role, role] }, selected: @user.role %></div>
  <%= form.submit "更新する", class: "primary-button" %>
<% end %>
