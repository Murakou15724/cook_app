<section class="page-title">
  <p class="eyebrow">Admin</p>
  <h1>献立管理</h1>
</section>

<section class="card">
  <% if @meal_plans.any? %>
    <% @meal_plans.each do |plan| %>
      <div class="dev-link-row">
        <span><%= plan.user.email %> / <%= app_date(plan.meal_date) %> / <%= meal_type_label(plan.meal_type) %></span>
      </div>
    <% end %>
  <% else %>
    <p class="empty-state">献立はありません。</p>
  <% end %>
</section>
