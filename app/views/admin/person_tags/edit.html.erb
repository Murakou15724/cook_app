<section class="page-title">
  <p class="eyebrow">Admin</p>
  <h1>人物タグ編集</h1>
</section>

<%= form_with url: admin_person_tag_path(@person_tag), method: :patch, class: "form-card" do |form| %>
  <div class="form-group"><%= form.label :name, "人物名" %><%= form.text_field :name, value: @person_tag.name %></div>
  <%= form.submit "更新する", class: "primary-button" %>
<% end %>
